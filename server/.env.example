# PostgreSQL connection string from Railway
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/cacyouth

# Admin console password (must match VITE_ADMIN_PASSWORD in frontend)
ADMIN_PASSWORD=change-this-to-a-strong-password

# Port (Railway sets this automatically)
PORT=3001

# Public URL of this API server (used as OPay callbackUrl)
API_URL=http://localhost:3001

# Frontend origin for CORS and OPay returnUrl/cancelUrl
FRONTEND_URL=http://localhost:5173

# ── OPay Credentials ─────────────────────────────────────────────────────────
# Get these from your OPay merchant dashboard → API Keys
OPAY_MERCHANT_ID=your-merchant-id
OPAY_PUBLIC_KEY=OPAYPRB_your_public_key_here
OPAY_PRIVATE_KEY=OPAYPRV_your_private_key_here
