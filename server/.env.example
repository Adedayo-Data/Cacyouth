# PostgreSQL — Railway auto-fills this when you add a PostgreSQL service
DATABASE_URL=postgresql://postgres:password@localhost:5432/cacyouth

# Admin console password (must match VITE_ADMIN_PASSWORD baked into frontend build)
ADMIN_PASSWORD=change-this-to-a-strong-password

# Port — Railway sets this automatically, leave blank locally
PORT=3001

# Public URL of this Railway service (used for OPay returnUrl / webhookUrl)
# Set this AFTER your first deploy once Railway gives you a domain.
# Example: https://cacyouth-production.up.railway.app
APP_URL=http://localhost:3001

# ── OPay Credentials ──────────────────────────────────────────────────────────
# From your OPay merchant dashboard → Settings → API Keys
OPAY_MERCHANT_ID=your-merchant-id
OPAY_PUBLIC_KEY=OPAYPRB_your_public_key_here
OPAY_PRIVATE_KEY=OPAYPRV_your_private_key_here

# Set to "production" on Railway to use OPay live API and disable sandbox
NODE_ENV=development
