# ── Backend API ───────────────────────────────────────────────
# URL of your Railway backend (no trailing slash)
# Local dev: http://localhost:3001
# Production: https://your-app.up.railway.app
VITE_API_URL=http://localhost:3001

# ── Admin Console ─────────────────────────────────────────────
# Must match ADMIN_PASSWORD in server/.env
VITE_ADMIN_PASSWORD=change-this-to-a-strong-password

# ── Flutterwave (payment — to be replaced by Opay) ────────────
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
