# ── Frontend build-time variables ────────────────────────────────────────────
# When hosting on Railway (frontend + backend on same domain), leave this EMPTY.
# The frontend will use relative /api/... paths automatically.
# Only set this if your frontend is on a different domain from the API.
VITE_API_URL=

# Admin console password — must match ADMIN_PASSWORD in server/.env
VITE_ADMIN_PASSWORD=change-this-to-a-strong-password
