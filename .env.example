# ── Flutterwave ───────────────────────────────────────────────
# Get this from your Flutterwave dashboard → Settings → API Keys
VITE_FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# ── Firebase ──────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Admin Console ─────────────────────────────────────────────
# Set a strong password for the admin login screen
VITE_ADMIN_PASSWORD=change-this-to-a-strong-password
